PORT=5000
NODE_ENV=production

# PostgreSQL — thay bằng URL từ Neon / Supabase / Render PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/itechzone?sslmode=require"

# JWT — đổi thành chuỗi ngẫu nhiên dài ít nhất 32 ký tự
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS — URL frontend trên Vercel (sau khi deploy)
CLIENT_URL=https://your-app.vercel.app

# ================================
# SEED ACCOUNTS (tự động tạo khi server start)
# ================================
ADMIN_EMAIL=admin@itechzone.vn
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Administrator

STAFF_EMAIL=staff@itechzone.vn
STAFF_PASSWORD=Staff@123
STAFF_NAME=Nhân viên bán hàng
